				annotation SummarizationSetBy = Automatic

			column 'Group Level Sort' =
					
					SWITCH( TRUE(),
					        'Levels in Subjects'[Level Sort] <= 2, 1,
					        'Levels in Subjects'[Level Sort] = 3, 2,
					        'Levels in Subjects'[Level Sort] <= 6, 3,
					        'Levels in Subjects'[Level Sort] <= 12, 4,
					        'Levels in Subjects'[Level Sort] = 13, 5,
					        'Levels in Subjects'[Level Sort] <= 15, 6,
