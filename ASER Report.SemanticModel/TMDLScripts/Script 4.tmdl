			measure 'Number Of Students v2' =
					
					VAR __CyclesActifs =
					    VALUES( Cycles[Cycle ID] )
					
					VAR __LevelsActifs =
					    VALUES( 'Levels in Subjects'[Level ID] )
					
					VAR __NbDistinctCycles =
					    COUNTROWS( __CyclesActifs )
					
					-- Table dédupliquée filtrée par Cycle et Level du contexte
					VAR __BaseTable =
					    SUMMARIZE(
					        FILTER(
					            'ASER CIV Data',
					            'ASER CIV Data'[Cycle ID] IN __CyclesActifs &&
					            'ASER CIV Data'[Level ID] IN __LevelsActifs
					        ),
					        'ASER CIV Data'[School ID],
					        'ASER CIV Data'[Grade ID],
					        'ASER CIV Data'[Cycle ID],
					        "@Effectif", MAX( 'ASER CIV Data'[Students In Class] )
					    )
					
					-- ── CAS 1 : Cycle unique ────────────────────────────────────────────────────
					VAR __SingleCycle =
					    SUMX( __BaseTable, [@Effectif] )
					
					-- ── CAS 2 : Multi-cycles ────────────────────────────────────────────────────
					-- Étape 1 : effectif de chaque école pour chaque cycle (somme des classes)
					VAR __EffectifParEcoleParCycle =
					    ADDCOLUMNS(
					        SUMMARIZE( __BaseTable,
					            'ASER CIV Data'[School ID],
					            'ASER CIV Data'[Cycle ID]
					        ),
					        "@EffectifCycle",
					            VAR __CurSchool = 'ASER CIV Data'[School ID]
					            VAR __CurCycle  = 'ASER CIV Data'[Cycle ID]
					            RETURN
					                SUMX(
					                    FILTER( __BaseTable,
					                        'ASER CIV Data'[School ID] = __CurSchool &&
					                        'ASER CIV Data'[Cycle ID]  = __CurCycle
					                    ),
					                    [@Effectif]
					                )
					    )
					
					-- Étape 2 : pour chaque école, MAX des effectifs sur les cycles
					VAR __MaxParEcole =
					    ADDCOLUMNS(
					        SUMMARIZE( __EffectifParEcoleParCycle,
					            'ASER CIV Data'[School ID]
					        ),
					        "@MaxEffectif",
					            VAR __CurSchool = 'ASER CIV Data'[School ID]
					            RETURN
					                MAXX(
					                    FILTER( __EffectifParEcoleParCycle,
					                        'ASER CIV Data'[School ID] = __CurSchool
					                    ),
					                    [@EffectifCycle]
					                )
					    )
					
					-- Étape 3 : somme des maximums
					VAR __MultiCycle =
					    SUMX( __MaxParEcole, [@MaxEffectif] )
					
					RETURN
					    IF( __NbDistinctCycles = 1, __SingleCycle, __MultiCycle )
				formatString: 0
				lineageTag: 924e9b8e-7660-4c52-aa6c-ec513cbf541e

