	measure 'Comment - Lower Levels across cycles' = ```
			
			
			VAR __Subject = SELECTEDVALUE( 'Levels in Subjects'[Subject ID] )
			
			VAR __BL2 =
			SWITCH( __Subject,
			        1, [% Of Students With Low Literacy At BL],
			        2, [% Of Students With Low Numeracy At BL],
			        BLANK() )
			
			VAR __EL2 =
			SWITCH( __Subject,
			        1, [% Of Students With Low Literacy At EL],
			        2, [% Of Students With Low Numeracy At EL],
			        BLANK() )
			
			VAR __pp2 = [pp Of Subject Difficulty Reduction From BL to EL (formated)]
			
			VAR __pp_target2 = -20
			
			VAR __pp_gap2 = __pp_target2 + __pp2
			
			VAR __pp_formated2 =
			SWITCH( SIGN(__pp2),
			        1, FORMAT( ABS(__pp2), "-0 pp" ),
			        -1, FORMAT( ABS(__pp2), "+0 pp" ),
			        BLANK() )
			
			VAR __Level2 = 
			SWITCH( __Subject,
			        1, "could not read words",
			        2, "could not recognise 2-digit numbers",
			        BLANK() )
			
			// Comment for lower levels reduction
			
			VAR __Line1_2 =
			UNICHAR(10) & "• " & FORMAT( __BL2, "0%" ) & " of students " & __Level2 & " at Baseline"
			
			VAR __Line2_2 =
			SWITCH( TRUE(),
			        __EL2 > __BL2, UNICHAR(10) & "• Increased to " & FORMAT( __EL2, "0%" ) & " at Endline",
			        __EL2 < __BL2, UNICHAR(10) & "• Reduced to " & FORMAT( __EL2, "0%" ) & " at Endline",
			        __EL2 = __BL2, UNICHAR(10) & "• Remain stable at Endline",
			        BLANK() )
			
			VAR __Line3_2 =
			UNICHAR(10) & "• The change in students who " & __Level2 & " was " & __pp_formated2
			
			VAR __Line4_2 = 
			SWITCH( SIGN(__pp_gap2),
			        1, UNICHAR(10) & "• The change was " & FORMAT( __pp_gap2, "0 pp" ) & " more than the target, which was set as " & __pp_target2 & " pp",
			        -1, UNICHAR(10) & "• The change was " & FORMAT( __pp_gap2, "0 pp" ) & " less than the target, which was set as " & __pp_target2 & " pp",
			        BLANK() )
			
			VAR Comment = __Line1_2 & __Line2_2 & __Line3_2 & __Line4_2
			
			RETURN IF( ISBLANK(__EL2),
			   "Endline data not available for the current year",
			   Comment )
			```
		lineageTag: 95384443-db47-47ac-b99a-67c4870924e2

