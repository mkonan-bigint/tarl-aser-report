	measure '# Of Red schools for Literacy' =
			
				VAR __BaseTable = SUMMARIZE(
					'ASER CIV Data',
					'ASER CIV Data'[School ID],
					'ASER CIV Data'[Period],
					"@Progress in Literacy from BL to EL", [pp Of Literacy Improvemnt From BL to EL],
					"@Progress in Numeracy from BL to EL", [pp Of Numeracy Improvemnt From BL to EL]
				)
			
				VAR __Table = SELECTCOLUMNS(
					__BaseTable,
					"@School ID", 'ASER CIV Data'[School ID],
					"@Period", 'ASER CIV Data'[Period],
					"@Literacy Status", SWITCH(
						TRUE(),
						[@Progress in Literacy from BL to EL] = BLANK(), BLANK(),
						[@Progress in Literacy from BL to EL] < 0.1, "Red school (0-10pp)",
						[@Progress in Literacy from BL to EL] < 0.15, "Lower Yellow school (10-15pp)",
						[@Progress in Literacy from BL to EL] < 0.20, "Intermediate Yellow school (15-20pp)",
						[@Progress in Literacy from BL to EL] < 0.25, "Upper Yellow school (20-25pp)",
						"Green school (>25pp)"
					)
				)
			
				VAR __Red_Schools = FILTER(
					__Table,
					[@Literacy Status] = "Red school (0-10pp)"
				)
			
			    VAR __Result = COUNTROWS( __Red_Schools )
			
			    RETURN __Result
		formatString: #,0
		displayFolder: 2. Program specific KPIs
		lineageTag: 72502e7f-3519-41b2-93bc-4d0c974d0f74

	measure '# Of Lower Yellow schools for Literacy' =
			
