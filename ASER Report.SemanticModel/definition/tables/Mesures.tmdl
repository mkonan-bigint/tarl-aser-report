	measure 'Comment - High Literacy Progress across grades' = ```
			
			
			VAR __EL = [pp Of Literacy Improvemnt From BL to EL (formated)]
			VAR __Top_Grade = [Grade With Highest Literacy Improvement At EL]
			VAR __Bottom_Grade = [Grade With Lowest Literacy Improvement At EL]
			VAR __Top_Grade_Performance = [Highest Literacy Improvement across grades at EL]
			VAR __Bottom_Grade_Performance = [Lowest Literacy Improvement across grades at EL]
			VAR __Top_Grade_Performance_formated = FORMAT( 100 * __Top_Grade_Performance, "0 pp" )
			VAR __Bottom_Grade_Performance_formated = FORMAT( 100 * __Bottom_Grade_Performance, "0 pp" )
			VAR __List_Grades_Over_Target = [Grades With Literacy Improvement over 20pp]
			VAR __List_Grades_Under_Target = [Grades With Literacy Improvement under 20pp]
			VAR __Count_Grades = DISTINCTCOUNT( Grades[Grade] )
			VAR __Count_Grades_Over_Target = [# Of Grades With Literacy Improvement over 20pp]
			VAR __Count_Grades_Under_Target = [# Of Grades With Literacy Improvement under 20pp]
			
			VAR __Comment_Part1 = UNICHAR(10) & "• The best performance was seen in the " &  __Top_Grade & " class with " & __Top_Grade_Performance_formated & ". " & __Bottom_Grade & " was the class which performed the least with " & __Bottom_Grade_Performance_formated
			
			VAR __Comment_Part2 = 
			IF( __Count_Grades_Under_Target = 0,
			UNICHAR(10) & "• All grades meet the change target of 20 pp",
			UNICHAR(10) & "• " & __Count_Grades_Under_Target & " grade(s) out of " & __Count_Grades & " did not meet the change target of 20 pp : " & __List_Grades_Under_Target )
			
			VAR __Full_Comment = __Comment_Part1 & __Comment_Part2
			
			RETURN IF( ISBLANK(__EL),
			   "Endline data not available for the current year", __Full_comment )
			```
		lineageTag: 5396fc62-6e58-4f31-8fb2-1d74e5080aae

	measure 'Grade With Highest Literacy Improvement At EL' =
			
			VAR __Table =
			    ADDCOLUMNS(
			        VALUES( Grades[Grade] ),
			        "@Literacy At EL", CALCULATE( [pp Of Literacy Improvemnt From BL to EL] )
			    )
			VAR __MaxValue =
			    MAXX( __Table, [@Literacy At EL] )
			VAR __Result =
			    MAXX(
			        FILTER( __Table, [@Literacy At EL] = __MaxValue ),
			        Grades[Grade]
			    )
			RETURN
			    IF( ISBLANK( __MaxValue ), BLANK(), __Result )
