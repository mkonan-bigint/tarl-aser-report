	measure '# Of Students In Cycle' =
			
			VAR __CurrentCycle = MAX( Cycles[Cycle ID] )
			
			VAR __BaseTable = DISTINCT(SELECTCOLUMNS(
					'ASER CIV Data',
					"@Grade ID", 'ASER CIV Data'[Grade ID],
					"@Cycle ID", 'ASER CIV Data'[Cycle ID],
					"@Students In Class", 'ASER CIV Data'[Students In Class]
				))
			
			    VAR __FilteredTable = FILTER( __BaseTable, [@Cycle ID] = __CurrentCycle )
			
			RETURN SUMX( __FilteredTable, [@Students In Class] )
		formatString: #,0
		displayFolder: 1. Cycle specific KPIs
		lineageTag: 32a8b5ca-4fd8-4f29-8e78-d208d54298d1

	measure '# Of Students Tested In Cycle' =
			
			VAR __CurrentCycle = MAX( Cycles[Cycle ID] )
			VAR __CurrentSubject = MAX( 'ASER CIV Data'[Subject ID] )
			
			VAR __BaseTable = DISTINCT(SELECTCOLUMNS(
					'ASER CIV Data',
					"@Grade ID", 'ASER CIV Data'[Grade ID],
					"@Cycle ID", 'ASER CIV Data'[Cycle ID],
					"@Level ID", 'ASER CIV Data'[Level ID],
					"@Subject ID", 'ASER CIV Data'[Subject ID],
					"@Students At Level", 'ASER CIV Data'[Students At Level]
				))
			
			VAR __FilteredTable = FILTER( __BaseTable, [@Cycle ID] = __CurrentCycle  && [@Subject ID] = __CurrentSubject)
			
			RETURN SUMX( __FilteredTable, [@Students At Level] )
		formatString: #,0
		displayFolder: 1. Cycle specific KPIs
		lineageTag: 4589fda1-cd39-43d9-8eb0-b4e3ad2e6e2f

	measure '_# Of Students Reached In Program' =
			
			VAR __BaseTable =
			    SUMMARIZE (
			        'ASER CIV Data',
			        Cycles[Period],
			        'ASER CIV Data'[Cycle ID],
			        'ASER CIV Data'[School ID],
			        'ASER CIV Data'[Grade ID],
			        "@Effectif", MAX ( 'ASER CIV Data'[Students In Class] )
			    )
			
			VAR __TotalParCycle =
			    GROUPBY (
			        __BaseTable,
			        Cycles[Period],
			        'ASER CIV Data'[Cycle ID],
			        "@TotalCycle", SUMX ( CURRENTGROUP (), [@Effectif] )
			    )
			
			RETURN
			    MAXX ( __TotalParCycle, [@TotalCycle] )
		formatString: #,0
		displayFolder: 2. Program specific KPIs
		lineageTag: 24fd0b70-42c6-4753-ba54-2d4d41e7d508

	measure '% Change Rate Of Students Tested' =
			
			
			VAR __CurrentNumberOfStudents = [# Of Students Tested In Cycle]
			VAR __PreviousNumberOfStudents = [# Of Students Tested In Previous Cycle]
			VAR __NumberChange = __CurrentNumberOfStudents - __PreviousNumberOfStudents
			VAR __PercentageChange = DIVIDE( __NumberChange, __PreviousNumberOfStudents )
			RETURN __PercentageChange
		displayFolder: 0. Overall KPIs
		lineageTag: 20bfb364-664a-4ff1-be41-a72bc3ddca38

		formatStringDefinition = "+0 %;-0 %;0 %"

	measure '# Of Students Tested In Previous Cycle' =
			
			VAR __NumberOfCycles = 'Cycles interval'[Valeur Cycles Interval]
			VAR __CurrentCycle = MAX( Cycles[Cycle ID] ) - 'Cycles interval'[Valeur Cycles Interval]
			VAR __CurrentSubject = MAX( 'ASER CIV Data'[Subject ID] )
			
			VAR __BaseTable =
			    DISTINCT(
			        SELECTCOLUMNS(
			            CALCULATETABLE(
			                'ASER CIV Data',
			                ALL( Cycles )
			            ),
			            "@Cycle ID",        'ASER CIV Data'[Cycle ID],
			            "@School ID",       'ASER CIV Data'[School ID],
			            "@Subject ID",      'ASER CIV Data'[Subject ID],
			            "@Students Tested", 'ASER CIV Data'[Students At Level]
			        )
			    )
			
			VAR __FilteredTable =
			    FILTER(
			        __BaseTable,
			        [@Cycle ID] = __CurrentCycle &&
			        [@Subject ID] = __CurrentSubject
			    )
			
			RETURN
			    SUMX( __FilteredTable, [@Students Tested] )
		formatString: #,0
		displayFolder: 1. Cycle specific KPIs
		lineageTag: 450a8c52-7905-4a81-9a13-73e707afd5b8

