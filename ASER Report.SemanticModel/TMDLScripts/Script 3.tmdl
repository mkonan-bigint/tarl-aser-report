			mAttributes: [ FunctionQueryBinding = "{""exemplarFormulaName"":""Transformer l\u0027exemple de fichier""}" ]
			lineageTag: a566f16d-b64e-4193-9ad6-381f9645f47a
			queryGroup: 'Transformer le fichier à partir de From 24_25 (2)\Requêtes d''assistance'

			annotation PBI_ResultType = Function

			annotation PBI_NavigationStepName = Navigation

		expression fx_ComparaisonColonnes =
				(Table1 as table, Table2 as table, Alias_Table1 as text, Alias_Table2 as text) =>
				let
				    // Récupérer les noms des colonnes des deux tables
				    Columns1 = Table.ColumnNames(Table1),
				    Columns2 = Table.ColumnNames(Table2),
				
				    // Trier les noms des colonnes des deux tables
				    SortedColumns1 = List.Sort(Columns1),
				    SortedColumns2 = List.Sort(Columns2),
				
				    // Comparer les colonnes (vérifie noms + ordre des colonnes)
				    SameColumns = SortedColumns1 = SortedColumns2,
				    TestResult = if SameColumns then "Les deux tables ont les mêmes colonnes" else "Il existe des colonnes divergentes entre les 2 tables",
				
				    // Détection des colonnes présentes dans Table1 mais absentes de Table2
				    MissingInTable2 = List.Difference(SortedColumns1, SortedColumns2),
				    Table1_MissingColumns = Table.FromList(MissingInTable2, Splitter.SplitByNothing(), {"Colonne"}),
				    ExistsInTable1 = Table.AddColumn(Table1_MissingColumns, "Présente dans la table", each Alias_Table1 ),
				    NotInTable2 = Table.AddColumn(ExistsInTable1, "Mais pas dans la table", each Alias_Table2 ),
				
				    // Détection des colonnes présentes dans Table2 mais absentes de Table1
				    MissingInTable1 = List.Difference(SortedColumns2, SortedColumns1),
				    Table2_MissingColumns = Table.FromList(MissingInTable1, Splitter.SplitByNothing(), {"Colonne"}),
				    ExistsInTable2 = Table.AddColumn(Table2_MissingColumns, "Présente dans la table", each Alias_Table2 ),
				    NotInTable1 = Table.AddColumn(ExistsInTable2, "Mais pas dans la table", each Alias_Table1 ),
				    // Fusion des résultats
				    DiffColumns = Table.Combine({NotInTable2, NotInTable1}),
				    // NEW : Ajout dans le record d'un champ donnant le nombre de lignes de la table des écarts
				    NonMatchingCount = Table.RowCount(DiffColumns),
				
				    Result = [
				              Test vérification = TestResult,
				              Nombre de colonnes divergentes = NonMatchingCount,
				              Vérifier les colonnes divergentes = DiffColumns
				              ]
				
				in
				    Result
