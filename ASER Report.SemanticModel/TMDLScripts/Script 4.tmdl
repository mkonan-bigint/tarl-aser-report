				sourceColumn: Level Sort

				annotation SummarizationSetBy = Automatic

			column 'Grouped Level' =
					SWITCH(
						TRUE,
						ISBLANK('Levels in Subjects'[Level]),
						"(Vide)",
						'Levels in Subjects'[Level] IN {"2-Digit"},
						"2-Digit",
						'Levels in Subjects'[Level] IN {"Paragraph",
							"Story",
							"Comprehension"},
						"Can read at least a simple paragraph",
						'Levels in Subjects'[Level] IN {"Substraction",
							"Division"},
						"Can solve at least 2x2 subtraction operation",
						'Levels in Subjects'[Level] IN {"Beginner L",
							"Letter"},
						"Cannot read words",
						'Levels in Subjects'[Level] IN {"Beginner N",
							"1-Digit"},
						"Cannot recognize 2-digit",
						'Levels in Subjects'[Level] IN {"Word"},
						"Word",
						'Levels in Subjects'[Level]
					)
				lineageTag: 412e89ff-3482-4024-8046-4196cbf45b0a
				summarizeBy: none
				sortByColumn: 'Group Level Sort'

				extendedProperty GroupingMetadata = {"version":0,"groupedColumns":[{"Column":{"Expression":{"SourceRef":{"Entity":"Levels in Subjects"}},"Property":"Level"}}]}

