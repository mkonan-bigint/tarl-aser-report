	measure 'Comment - Mentor Visits across DRENAETs' = ```
			
			
			VAR __Avg = [Average Number Of Mentoring School Visits]
			VAR __Count_Other_Group_DRENAET = [# Of DRENAETs With More Other Mentoring Visits than CPPP Visits]
			VAR __List_Other_Group_DRENAET = [DRENAETs With More Other Mentoring Visits than CPPP Visits]
			VAR __Top2_CPPP_DRENAET = [Top 2 DRENAETs With Highest Average Number Of CPPP Visits]
			VAR __Top2_Other_Group_DRENAET = [Top 2 DRENAETs With Highest Average Number Of Other Mentoring Group Visits]
			
			VAR __Comment_Line1 = UNICHAR(10) & "• " & __Top2_CPPP_DRENAET & " stand out as the DRENAETs with the most intensive monitoring by CPPP group."
			
			VAR __Comment_Line2 = UNICHAR(10) & "• " & __Top2_Other_Group_DRENAET & " stand out as the DRENAETs with the most intensive monitoring by Other monitoring groups."
			
			VAR __Comment_Line3 = 
			SWITCH( TRUE(),
			     __Count_Other_Group_DRENAET = 1, UNICHAR(10) & "• There is 1 DRENAET where the average number of other mentoring visits is higher than CPPP visits: " & __List_Other_Group_DRENAET,
			     __Count_Other_Group_DRENAET > 1, UNICHAR(10) & "• There are " &  __Count_Other_Group_DRENAET & " DRENAETs where the average number of other mentoring visits is higher than CPPP visits: " & __List_Other_Group_DRENAET,
			    BLANK() )
			
			VAR __Full_Comment = __Comment_Line1 & __Comment_Line2 & __Comment_Line3
			
			RETURN IF( ISBLANK(__Avg),
			   "Data not available for the current cycle", __Full_comment )
			```
