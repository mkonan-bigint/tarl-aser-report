			VAR __Bottom_DRENAET_Performance = [Lowest Literacy Improvement across DRENAET at EL]
			VAR __Top_DRENAET_Performance_formated = FORMAT( 100 * __Top_DRENAET_Performance, "0 pp" )
			VAR __Bottom_DRENAET_Performance_formated = FORMAT( 100 * __Bottom_DRENAET_Performance, "0 pp" )
			
			VAR __Comment_Part1 = UNICHAR(10) & "• " & __Top_DRENAET & " showed the greatest improvement with " & __Top_DRENAET_Performance_formated
			
			VAR __Comment_Part2 = UNICHAR(10) & "• " & __Bottom_DRENAET & " showed the smallest improvement with " & __Bottom_DRENAET_Performance_formated
			
			VAR __Full_Comment = __Comment_Part1 & __Comment_Part2
			
			RETURN IF( ISBLANK(__EL),
			   "Endline data not available for the current year", __Full_comment )
