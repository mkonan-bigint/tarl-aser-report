	measure 'Grades With Literacy Improvement over 20pp' =
			
			VAR __CurrentPeriod = SELECTEDVALUE( Cycles[Period] )
			VAR __CurrentSubject = 1
			VAR __Table =
			    ADDCOLUMNS(
			        SUMMARIZE( Grades, Grades[Grade], Grades[Grade Sort] ),
			        "@pp Improvement",
			            CALCULATE(
			                [pp Of Subject Improvemnt From BL to EL (formated)],
			                Cycles[Period] = __CurrentPeriod,
			                'Levels in Subjects'[Subject ID] = __CurrentSubject
			            )
			    )
			VAR __FilteredTable =
			    FILTER( __Table, NOT ISBLANK( [@pp Improvement] ) && [@pp Improvement] >= 20 )
			RETURN
			    IF(
			        ISEMPTY( __FilteredTable ),
			        BLANK(),
			        CONCATENATEX( __FilteredTable, Grades[Grade], ", ", Grades[Grade Sort], ASC )
			    )
		lineageTag: a7c4bf23-2c21-4bdf-8f87-7854d84b4988

