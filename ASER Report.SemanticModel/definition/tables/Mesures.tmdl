						[@Progress in Numeracy from BL to EL] < 0.15, "Lower Yellow school (10-15pp)",
						[@Progress in Numeracy from BL to EL] < 0.20, "Intermediate Yellow school (15-20pp)",
						[@Progress in Numeracy from BL to EL] < 0.25, "Upper Yellow school (20-25pp)",
						"Green school (>25pp)"
					)
				)
			
				VAR __Yellow_Schools = FILTER(
					__Table,
					[@Numeracy Status] = "Lower Yellow school (10-15pp)"
				)
			
			    VAR __Result = COUNTROWS( __Yellow_Schools )
			
			    RETURN __Result
