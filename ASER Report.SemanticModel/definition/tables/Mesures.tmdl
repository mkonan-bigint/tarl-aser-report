	measure '# Of Students With High Litteracy In Cycle' =
			
			VAR __CurrentCycle = MAX( Cycles[Cycle ID] )
			
				VAR __GradesData =
				SELECTCOLUMNS(
					'ASER CIV Data',
					"@Cycle ID", 'ASER CIV Data'[Cycle ID],
					"@Grade", RELATED( Grades[Grade] ),
			        "@Group Level", RELATED( 'Levels in Subjects'[Group Level Sort] ),
					"@Students At Level", 'ASER CIV Data'[Students At Level]
				)
			
			    VAR __FilteredTable = FILTER( __GradesData, [@Cycle ID] = __CurrentCycle  && [@Group Level] = 3)
			
			RETURN SUMX( __FilteredTable, [@Students At Level] )
		formatString: #,0
		displayFolder: 1. Cycle specific KPIs
