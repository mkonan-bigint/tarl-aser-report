model Model
	culture: fr-FR
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: fr-FR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transformer le fichier à partir de From 24_25 (2)'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transformer le fichier à partir de From 24_25 (2)\Requêtes d''assistance'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Sources Old Data'

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["New Data","Paramètre1","Exemple de fichier","Transformer le fichier","ASER_2021-2022","ASER_2022-2023","ASER_2023-2024","Old Data","ASER CIV Data","Grades","Cycles","Levels in Subjects","DRENAETs and Donors","Schools","IEPPs","Mesures","Cycles List"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","TMDLView_Desktop","DevMode"]

ref table 'ASER CIV Data'
