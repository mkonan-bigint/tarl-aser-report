			measure 'Number Of Students in Cycle' =
					
					VAR __ASER_sans_doublon = DISTINCT(SELECTCOLUMNS(
							'ASER Data CIV',
							"@Grade ID", 'ASER Data CIV'[Grade ID],
							"@Cycle ID", 'ASER Data CIV'[Cycle ID],
							"@School ID", 'ASER Data CIV'[School ID],
							"@Students In Class", 'ASER Data CIV'[Students In Class]
						))
					
					VAR __Table = SUMMARIZE( __ASER_sans_doublon,
							[@Grade ID],
							[@Cycle ID],
							[@School ID],
							"@Number Of Students", MAX('ASER Data CIV'[Students In Class])
						)
					
					VAR __Result = SUMX( __Table, [@Number Of Students])
					RETURN __Result
				formatString: #,0
				lineageTag: 0fff3ea4-189b-4482-8b07-dd9be72630e5

