					"@Progress in Literacy from BL to EL", [pp Of Litteracy Improvemnt From BL to EL],
					"@Progress in Numeracy from BL to EL", [pp Of Numeracy Improvemnt From BL to EL]
				)
			
				VAR __Table = SELECTCOLUMNS(
					__BaseTable,
					"@School ID", 'ASER CIV Data'[School ID],
					"@Period", 'ASER CIV Data'[Period],
					"@Numeracy Status", SWITCH(
						TRUE(),
						[@Progress in Numeracy from BL to EL] = BLANK(), BLANK(),
						[@Progress in Numeracy from BL to EL] < 0.1, "Red school (0-10pp)",
						[@Progress in Numeracy from BL to EL] < 0.25, "Yellow school (10-25pp)",
						"Green school (>25pp)"
					)
				)
			
				VAR __Red_Schools = FILTER(
					__Table,
					[@Numeracy Status] = "Red school (0-10pp)"
				)
			
			    VAR __Result = COUNTROWS( __Red_Schools )
			
			    RETURN __Result
		formatString: 0
		displayFolder: 2. Program specific KPIs
		lineageTag: 16265274-fda3-42d0-9bff-9c9f5a267232

