					    SUMMARIZECOLUMNS(
					        'ASER CIV Data'[School ID],
					        'ASER CIV Data'[Grade ID],
					        'Levels in Subjects'[Level],
					        Cycles[Cycle],
					        "@StudentsTested", MAX( 'ASER CIV Data'[Students At Level] )
