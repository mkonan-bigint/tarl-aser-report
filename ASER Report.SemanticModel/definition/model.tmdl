model Model
	culture: fr-FR
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: fr-FR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Sources Old Data'

	annotation PBI_QueryGroupOrder = 2

queryGroup 'Transform ASER New Data'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform ASER New Data\Requêtes d''assistance'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform Verification ASER'

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Transform Verification ASER\Requêtes d''assistance'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["New Data","Paramètre1","Exemple de fichier","Transformer le fichier","ASER_2021-2022","ASER_2022-2023","ASER_2023-2024","Old Data","ASER CIV Data","Mentoring Visits","ASER Verification","Grades","Cycles","Levels in Subjects","DRENAETs and Donors","Schools","IEPPs","Mesures","Cycles List","Paramètre2","Exemple de fichier (2)","Transformer le fichier (2)","Sample_Size"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","TMDLView_Desktop","DevMode"]

ref table 'ASER CIV Data'
ref table Grades
ref table Cycles
ref table 'Levels in Subjects'
ref table 'Entry Calendar'
ref table Mesures
ref table 'Cycles interval'
ref table 'Mentoring Visits'
ref table 'ASER Verification'

ref cultureInfo fr-FR

