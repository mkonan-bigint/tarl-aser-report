	measure 'Comment - Mentor Visits across Cycles' = ```
			
			
			VAR __EL = [Average Number Of Mentoring School Visits ML-EL]
			VAR __Gap_ML = [Average Number Of Mentoring School Visits Gap across Group BL-ML]
			VAR __Gap_EL = [Average Number Of Mentoring School Visits Gap across Group ML-EL]
			VAR __Change_CPPP = [Average Number Of Mentoring School Visits Change across cycles for CPPP]
			VAR __Change_Other_group = [Average Number Of Mentoring School Visits Change across cycles for Other group]
			VAR __Change_CPPP_formated = FORMAT( __Change_CPPP, "0.00" )
			VAR __Change_Other_group_formated = FORMAT( __Change_Other_group, "0.00" )
			
			VAR __Comment_Line1 = 
			SWITCH( TRUE(),
			       __Gap_ML > 0 && __Gap_EL > 0, UNICHAR(10) & "• Overall, the average number of visits is greater for CPPP group than other mentoring groups",
			
			       __Gap_ML > 0 && __Gap_EL < 0, UNICHAR(10) & "• The average number of visits was greater for CPPP group than other mentoring groups only in the first phase",
			
			       __Gap_ML < 0 && __Gap_EL > 0, UNICHAR(10) & "• The average number of visits was greater for CPPP group than other mentoring groups only in the second phase",
			
			       __Gap_ML < 0 && __Gap_EL < 0, UNICHAR(10) & "• Overall, the average number of visits is smaller for CPPP group than other mentoring groups",
			
			      BLANK()
			)
			
			VAR __Comment_Line2 = 
			SWITCH( TRUE(),
			       __Change_CPPP > 0 && __Change_Other_group > 0, UNICHAR(10) & "• Between the two phases, the average number of visits increased for both CPPP(+" & __Change_CPPP_formated  & ") and Other mentoring groups(+" & __Change_Other_group_formated & ")",
			
			       __Change_CPPP > 0 && __Change_Other_group < 0, UNICHAR(10) & "• Between the two phases, the average number of visits increased for CPPP(+" & __Change_CPPP_formated  & "), but not for Other mentoring groups(" & __Change_Other_group_formated & ")",
			
			       __Change_CPPP < 0 && __Change_Other_group > 0, UNICHAR(10) & "• Between the two phases, the average number of visits increased for Other mentoring groups(+" & __Change_Other_group_formated  & "), but not for CPPP (" & __Change_CPPP_formated & ")",
			
			       __Change_CPPP < 0 && __Change_Other_group < 0, UNICHAR(10) & "• Between the two phases, the average number of visits decreased for both CPPP(" & __Change_CPPP_formated  & ") and Other mentoring groups(" & __Change_Other_group_formated & ")",
			       
			      BLANK()
			)
			
			VAR __Full_Comment = __Comment_Line1 & __Comment_Line2
			
			RETURN IF( ISBLANK(__EL),
			   "Endline data not available for the current year", __Full_comment )
			```
		lineageTag: 72c9b9c1-096f-47f3-8060-aae6fb1a0873

