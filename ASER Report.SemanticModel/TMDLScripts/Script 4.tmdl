			measure 'Percentage Change Rate Of Students Tested' =
					
					
					VAR __CurrentNumberOfStudents = [Number Of Students Tested In Cycle]
					VAR __PreviousNumberOfStudents = [Number Of Students Tested In Previous Cycle]
					VAR __NumberChange = __CurrentNumberOfStudents - __PreviousNumberOfStudents
					VAR __PercentageChange = DIVIDE( __NumberChange, __PreviousNumberOfStudents )
					RETURN __PercentageChange
				formatString: 0.0\ %;-0.0\ %;0.0\ %
