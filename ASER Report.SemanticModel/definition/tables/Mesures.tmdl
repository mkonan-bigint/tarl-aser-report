	measure 'Comment - Mentor Visits per School across DRENAETs' = ```
			
			
			VAR __Visits = [# Of Visits]
			VAR __Zero_Visits_Pct = FORMAT( [% Of Schools with 0 mentor visit], "0%" )
			VAR __One_Or_More_Visits_DRENAET_Pct = FORMAT( [% Of Schools with at least 1 mentor visit], "0%" )
			VAR __Seven_Or_More_Visits_DRENAET = [# Of DRENAETs Where % Of Schools With At Least 7 Mentor Visits is greater than 0]
			VAR __List_Seven_Or_More_Visits_DRENAET = [DRENAETs Where % Of Schools With At Least 7 Mentor Visits is greater than 0]
			VAR __Top2_Seven_Or_More_Visits_DRENAET = [Top 2 DRENAETs With Highest % Of Schools With At Least 7 Mentor Visits]
			
			
			VAR __Comment_Line1 = UNICHAR(10) & "• Overall, " & __Zero_Visits_Pct & " of schools had 0 mentor visit, and " & __One_Or_More_Visits_DRENAET_Pct & " had at least 1"
			
			VAR __Comment_Line2 =
			SWITCH ( TRUE(),
			   __Seven_Or_More_Visits_DRENAET = 0,
			   UNICHAR(10) & "• There is no DRENAET where a school had at least 7 mentor visits",
			
			   __Seven_Or_More_Visits_DRENAET = 1, 
			   UNICHAR(10) & "• There only 1 DRENAET with schools which had at least 7 mentor visits: " & __List_Seven_Or_More_Visits_DRENAET,
			
			   __Seven_Or_More_Visits_DRENAET > 1,
			   UNICHAR(10) & "• There are " & __Seven_Or_More_Visits_DRENAET & " DRENAETs with schools which had at least 7 mentor visits, including " & __Top2_Seven_Or_More_Visits_DRENAET,
			
			   BLANK() )
			
			VAR __Full_Comment = __Comment_Line1 & __Comment_Line2
			
			RETURN 
			IF( ISBLANK(__Visits),
			   "No data available for the current cycle", __Full_comment )
