	measure 'Comment - School Literacy Progress across DRENAETs' =
			
			
			VAR __EL = [pp Of Literacy Improvemnt From BL to EL (formated)]
			VAR __Top2_Lowest_Red_Schools = [Top 2 DRENAETs With Lowest % Of Red Schools For Literacy]
			VAR __Top2_Highest_Red_Schools = [Top 2 DRENAETs With Highest % Of Red Schools For Literacy]
			VAR __Overall_Red_Schools_Percentage = FORMAT( [% Of Red Schools For Literacy], "0%" )
			VAR __Overall_Lower_Yellow_Schools_Percentage = FORMAT( [% Of Lower Yellow Schools For Literacy], "0%" )
			VAR __Overall_Inter_Yellow_Schools_Percentage = FORMAT( [% Of Intermediate Yellow Schools For Literacy], "0%" )
			VAR __Overall_Upper_Yellow_Schools_Percentage = FORMAT( [% Of Upper Yellow Schools For Literacy], "0%" )
			VAR __Overall_Green_Schools_Percentage = FORMAT ( [% Of Green Schools For Literacy], "0%" )
			
			
			VAR __Comment_Line1 = UNICHAR(10) & "• " & __Top2_Lowest_Red_Schools & " are the DRENAETs with the fewest percentage of red schools"
			
			VAR __Comment_Line2 = UNICHAR(10) & "• " & __Top2_Highest_Red_Schools & " are the DRENAETs with the highest percentage of red schools"
			
			VAR __Comment_Line3 = UNICHAR(10) & UNICHAR(10) & "• Overall, there are " & __Overall_Red_Schools_Percentage & " red schools, " & __Overall_Lower_Yellow_Schools_Percentage & " lower yellow schools, " & __Overall_Inter_Yellow_Schools_Percentage & " intermediate yellow schools, " & __Overall_Upper_Yellow_Schools_Percentage & " upper yellow schools, and " & __Overall_Green_Schools_Percentage & " green schools"
			
			VAR __Full_Comment = __Comment_Line1 & __Comment_Line2 & __Comment_Line3
			
			RETURN IF( ISBLANK(__EL),
			   "Endline data not available for the current year", __Full_comment )
		lineageTag: 610820a0-e509-42f2-a3a2-f9e51bd9484e

	measure 'Top 2 DRENAETs With Lowest % Of Red Schools For Literacy' =
			
			VAR __Table =
			    ADDCOLUMNS(
			        VALUES( Grades[DRENAET] ),
			        "@Pct", CALCULATE( [% Of Red Schools For Literacy] )
			    )
			VAR __FilteredTable =
			    FILTER( __Table, NOT ISBLANK( [@Pct] ) && [@Pct] > 0 )
			VAR __Top2 =
			    TOPN( 2, __FilteredTable, [@Pct], ASC )
			RETURN
			    IF(
			        ISEMPTY( __Top2 ),
			        BLANK(),
			        CONCATENATEX(
			            __Top2,
			            Grades[DRENAET] & " (" & FORMAT( [@Pct], "0%" ) & ")",
			            " and ",
			            [@Pct], ASC
			        )
			    )
		lineageTag: 9a810743-28bb-41a6-9f7f-3c3239904517

