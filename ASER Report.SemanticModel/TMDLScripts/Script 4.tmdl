			measure 'Number Of Students Tested' = ```
					
					VAR __NbDistinctCycles =
					    COUNTROWS( VALUES( Cycles[Cycle ID] ) )
					
					-- Table dédupliquée : une ligne par (School, Grade, Cycle)
					-- La table ramène le nombre d'élèves testés de chaque classe à chaque cycle
					VAR __BaseTable =
					    SUMMARIZE(
					        'ASER CIV Data',
					        'ASER CIV Data'[School ID],
					        'ASER CIV Data'[Grade ID],
					        'ASER CIV Data'[Cycle ID],
					        'ASER CIV Data'[Level ID],
					        "@StudentsTested", MAX( 'ASER CIV Data'[Students At Level] )
					    )
					
					-- ── CAS 1 : Cycle unique
					VAR __SingleCycle =
					    SUMX( __BaseTable, [@StudentsTested] )
					
					-- ── CAS 2 : Multi-cycles
					-- Étape 1 : Nombre d'élèves testés de chaque école pour chaque cycle
					VAR __NombreParEcoleParCycle =
					    SUMMARIZE(
					        __BaseTable,
					        'ASER CIV Data'[School ID],
					        'ASER CIV Data'[Cycle ID],
					        'ASER CIV Data'[Level ID],
					        "@NbTestedCycle",
					            VAR __CurSchool = 'ASER CIV Data'[School ID]
					            VAR __CurCycle  = 'ASER CIV Data'[Cycle ID]
					            VAR __CurLevel = 'ASER CIV Data'[Level ID]
					            RETURN
					                SUMX(
					                    FILTER( __BaseTable,
					                        'ASER CIV Data'[School ID] = __CurSchool &&
					                        'ASER CIV Data'[Cycle ID]  = __CurCycle &&
					                        'ASER CIV Data'[Level ID] = __CurLevel
					                    ),
					                    [@StudentsTested]
					                )
					    )
					
					-- Étape 2 : pour chaque école, MAX des nombre d'élèves testés sur les cycles
					VAR __MaxParEcole =
					    SUMMARIZE(
					        __NombreParEcoleParCycle,
					        'ASER CIV Data'[School ID],
					        "@MaxTested", 
					        VAR __CurSchool = 'ASER CIV Data'[School ID]
					        RETURN
					            MAXX(
					                FILTER( __NombreParEcoleParCycle,
					                    'ASER CIV Data'[School ID] = __CurSchool
					                ),
					                [@NbTestedCycle]
					        )
					    )
					
					-- Étape 3 : somme des maximums
					VAR __MultiCycle =
					    SUMX( __MaxParEcole, [@MaxTested] )
					
					RETURN
					    IF( __NbDistinctCycles = 1, __SingleCycle, __MultiCycle )
					```
				formatString: #,0
				lineageTag: c8508836-87c2-4342-895c-9515020a5074

			measure 'Number Of Students In Cycle' =
					
					VAR __CurrentCycle = MAX( Cycles[Cycle ID] )
					
						VAR __BaseTable = DISTINCT(SELECTCOLUMNS(
							'ASER Cycles Data',
							"@Cycle ID", 'ASER Cycles Data'[Cycle ID],
							"@School ID", 'ASER Cycles Data'[School ID],
							"@Students In School", 'ASER Cycles Data'[Students In School]
						))
					
					    VAR __FilteredTable = FILTER( __BaseTable, [@Cycle ID] = __CurrentCycle )
					
					RETURN SUMX( __FilteredTable, [@Students In School] )
				formatString: #,0
				lineageTag: 32a8b5ca-4fd8-4f29-8e78-d208d54298d1

			measure 'Number Of Students Tested BL' =
					
