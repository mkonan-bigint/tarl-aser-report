	measure 'Compared To Cycle' =
			
			VAR __CurrentCycleID = MAX( Cycles[Cycle ID] )
			VAR __CurrentCycle = MAX( Cycles[Cycle Name] )
			VAR __ComparedToID = __CurrentCycleID - 'Cycles interval'[Valeur Cycles Interval]
			VAR __ComparedToName = LOOKUPVALUE( Cycles[Cycle Name], Cycles[Cycle ID], __ComparedToID)
			
			RETURN __ComparedToName
		displayFolder: 1. Cycle specific KPIs
		lineageTag: 063a0961-39b6-44c8-8f64-9217198fd396

