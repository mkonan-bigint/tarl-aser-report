			measure 'Number Of Students Tested In Previous Cycle' =
					
					
					VAR __NumberOfCycles = 'Cycles interval'[Valeur Cycles Interval]
					VAR __CurrentCycle = MAX( Cycles[Cycle ID] ) - 'Cycles interval'[Valeur Cycles Interval]
					--VAR __CurrentCycle = MAX( 'Compared To Cycles'[Cycle ID] )
					VAR __CurrentSubject = MAX( 'ASER CIV Data'[Subject ID] )
					
					VAR __BaseTable =
					    DISTINCT(
					        SELECTCOLUMNS(
					            CALCULATETABLE(
					                'ASER Cycles Data',
					                ALL( Cycles )
					            ),
					            "@Cycle ID",        'ASER Cycles Data'[Cycle ID],
					            "@School ID",       'ASER Cycles Data'[School ID],
					            "@Subject ID",      'ASER Cycles Data'[Subject ID],
					            "@Students Tested", 'ASER Cycles Data'[Students At Level]
					        )
					    )
					
					VAR __FilteredTable =
					    FILTER(
					        __BaseTable,
					        [@Cycle ID] = __CurrentCycle &&
					        [@Subject ID] = __CurrentSubject
					    )
					
					RETURN
					    SUMX( __FilteredTable, [@Students Tested] )
